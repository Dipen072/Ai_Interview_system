# Force Unix LF line endings for shell scripts and Docker files
# This prevents CRLF issues when developing on Windows
* text=auto

# Shell scripts MUST have LF endings (not CRLF) to run on Linux
*.sh text eol=lf
docker/start.sh text eol=lf
docker/nginx.conf text eol=lf
docker/supervisord.conf text eol=lf
Dockerfile text eol=lf
