APP_NAME="AI Interview System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app-name.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

# Logging — stderr works best in Docker / Render
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database (Render auto-fills these from the linked PostgreSQL) ───────────
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Session / Cache (file driver — no Redis required on free tier) ──────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Mail (use 'log' to skip real mail in production until configured) ────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AI Provider (set in Render Dashboard → Environment → Secret Files) ───────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
